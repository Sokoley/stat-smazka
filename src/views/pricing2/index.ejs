<%- include('../layouts/main', { title, body: `
<style>
  .pricing2-container { max-width: 100%; margin: 0 auto; }
  .pricing2-title { font-size: 1.5rem; font-weight: 700; color: #111827; margin-bottom: 1rem; }
  .dark .pricing2-title { color: #f9fafb; }
  .pps-table-wrap { overflow-x: auto; border-radius: 8px; border: 1px solid #e5e7eb; }
  .dark .pps-table-wrap { border-color: #374151; }
  .pps-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .pps-table th { background: #f9fafb; color: #374151; font-weight: 600; text-align: left; padding: 0.75rem 1rem; white-space: nowrap; }
  .dark .pps-table th { background: #374151; color: #e5e7eb; }
  .pps-table td { padding: 0.75rem 1rem; border-top: 1px solid #e5e7eb; color: #111827; }
  .dark .pps-table td { border-top-color: #374151; color: #e5e7eb; }
  .pps-table tbody tr:nth-child(even) { background: #f9fafb; }
  .dark .pps-table tbody tr:nth-child(even) { background: #1f2937; }
  .pps-table tbody tr:hover { background: #f3f4f6; }
  .dark .pps-table tbody tr:hover { background: #374151; }
  .pps-table .num { text-align: right; font-variant-numeric: tabular-nums; }
  .pps-table .img-cell { width: 64px; padding: 0.25rem; vertical-align: middle; }
  .pps-table .img-cell img { max-width: 56px; max-height: 56px; object-fit: contain; display: block; }
  #ppsError { display: none; padding: 1rem; border-radius: 8px; background: #fef2f2; color: #b91c1c; margin-bottom: 1rem; }
  .dark #ppsError { background: #7f1d1d; color: #fecaca; }
  #ppsError.show { display: block; }
  .btn-refresh { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; background: #2563eb; color: white; border-radius: 6px; font-weight: 500; border: none; cursor: pointer; }
  .btn-refresh:hover { background: #1d4ed8; }
  .btn-refresh:disabled { opacity: 0.6; cursor: not-allowed; }
  .pps-table th .filter-select { margin-top: 0.25rem; display: block; width: 100%; min-width: 180px; padding: 0.375rem 0.5rem; font-size: 0.8125rem; border: 1px solid #d1d5db; border-radius: 4px; background: #fff; color: #374151; }
  .dark .pps-table th .filter-select { background: #1f2937; border-color: #4b5563; color: #e5e7eb; }
  .pricing2-progress { display: none; margin-bottom: 1rem; }
  .pricing2-progress.visible { display: block; }
  .pricing2-progress-bar-wrap { height: 24px; background: #e5e7eb; border-radius: 12px; overflow: hidden; }
  .dark .pricing2-progress-bar-wrap { background: #374151; }
  .pricing2-progress-bar { height: 100%; background: linear-gradient(90deg, #2563eb, #3b82f6); border-radius: 12px; transition: width 0.3s ease; width: 0%; }
  .pricing2-progress-label { margin-top: 0.5rem; font-size: 0.875rem; color: #6b7280; }
  .dark .pricing2-progress-label { color: #9ca3af; }
  .competitors-cell { min-width: 180px; }
  .competitors-cell .add-form { display: flex; gap: 0.25rem; align-items: center; flex-wrap: wrap; }
  .competitors-cell input.competitor-sku { width: 90px; padding: 0.25rem 0.5rem; font-size: 0.8125rem; }
  .competitors-cell .btn-add-competitor { padding: 0.25rem 0.5rem; font-size: 0.75rem; cursor: pointer; }
  .competitors-cell .competitor-tag { display: inline-flex; align-items: center; gap: 0.25rem; margin: 0.25rem 0.25rem 0 0; padding: 0.2rem 0.4rem; background: #e5e7eb; border-radius: 4px; font-size: 0.75rem; }
  .dark .competitors-cell .competitor-tag { background: #4b5563; }
  .competitors-cell .competitor-tag .btn-remove-competitor { background: none; border: none; cursor: pointer; padding: 0 0.2rem; color: #6b7280; font-size: 1rem; line-height: 1; }
  .competitors-cell .competitor-tag .btn-remove-competitor:hover { color: #ef4444; }
  .pps-table tr.competitor-row { border-left: 3px solid #94a3b8; }
  .dark .pps-table tr.competitor-row { border-left-color: #64748b; }
  .pps-table tr.competitor-row td { font-size: 0.8125rem; background: #e2e8f0; padding-left: 1.25rem; }
  .dark .pps-table tr.competitor-row td { background: #334155; }
  .pps-table tr.competitor-row td:first-child { padding-left: 2rem; color: #475569; }
  .dark .pps-table tr.competitor-row td:first-child { color: #94a3b8; }
  .pps-table tr.competitor-row td a { color: inherit; text-decoration: none; }
  .pps-table tr.competitor-row td a:hover { text-decoration: underline; color: #2563eb; }
  .dark .pps-table tr.competitor-row td a:hover { color: #60a5fa; }
</style>

<div class="pricing2-container space-y-4">
  <h1 class="pricing2-title">Ценообразование 2.0</h1>

  <div class="flex items-center gap-3 flex-wrap">
    <button type="button" id="btnRefresh" class="btn-refresh" onclick="loadPps()">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Обновить
    </button>
  </div>

  <div id="pricing2Progress" class="pricing2-progress">
    <div class="pricing2-progress-bar-wrap">
      <div id="pricing2ProgressBar" class="pricing2-progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
    </div>
    <div id="pricing2ProgressLabel" class="pricing2-progress-label">Загрузка PPS...</div>
  </div>

  <div id="ppsError">
    <strong>Ошибка:</strong> <span id="ppsErrorText"></span>
  </div>

  <div class="pps-table-wrap">
    <table class="pps-table">
      <thead>
        <tr>
          <th>Артикул</th>
          <th class="img-cell">Фото</th>
          <th>Номенклатура</th>
          <th>
            Вид товара
            <select id="filterVidTovara" class="filter-select hidden" title="Фильтр по виду товара">
              <option value="">Все виды</option>
            </select>
          </th>
          <th class="num">Заливочная цена</th>
          <th class="num">Цена по OZON карте</th>
          <th class="num">Продажи за период</th>
          <th class="num">Продажи, руб</th>
          <th class="num">Рекомендованная цена</th>
          <th>Конкуренты</th>
        </tr>
      </thead>
      <tbody id="ppsBody">
        <tr>
          <td colspan="10" class="text-center py-8 text-gray-500 dark:text-gray-400">Нажмите «Обновить» для загрузки данных</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  var ppsDataAll = [];
  var ozonInfo = {};
  var mpstatsData = {};
  var competitorsByArticul = {};
  function saveOurProductsToServer() {
    var ourSkus = {};
    for (var k in ozonInfo) { if (ozonInfo[k].sku != null) ourSkus[ozonInfo[k].sku] = true; }
    var ourMpstats = {};
    for (var sku in mpstatsData) { if (ourSkus[Number(sku)]) ourMpstats[sku] = mpstatsData[sku]; }
    fetch('/pricing2/api/save-our-products', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ppsData: ppsDataAll, ozonInfo: ozonInfo, mpstatsData: ourMpstats })
    }).catch(function(e) { console.error('save-our-products', e); });
  }
  function saveCompetitorsToServer() {
    var compSkus = {};
    for (var a in competitorsByArticul) {
      (competitorsByArticul[a] || []).forEach(function(s) { compSkus[Number(s)] = true; });
    }
    var compMpstats = {};
    for (var sku in mpstatsData) { if (compSkus[Number(sku)]) compMpstats[sku] = mpstatsData[sku]; }
    fetch('/pricing2/api/save-competitors', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ competitorsByArticul: competitorsByArticul, mpstatsData: compMpstats })
    }).catch(function(e) { console.error('save-competitors', e); });
  }

  function showError(msg) {
    var el = document.getElementById('ppsError');
    document.getElementById('ppsErrorText').textContent = msg || '';
    el.classList.add('show');
  }
  function hideError() {
    document.getElementById('ppsError').classList.remove('show');
  }
  function setLoading(loading) {
    document.getElementById('btnRefresh').disabled = loading;
  }
  function setProgress(percent, label) {
    var wrap = document.getElementById('pricing2Progress');
    var bar = document.getElementById('pricing2ProgressBar');
    var lbl = document.getElementById('pricing2ProgressLabel');
    wrap.classList.add('visible');
    bar.style.width = Math.min(100, Math.max(0, percent)) + '%';
    bar.setAttribute('aria-valuenow', percent);
    if (label) lbl.textContent = label;
  }
  function hideProgress() {
    document.getElementById('pricing2Progress').classList.remove('visible');
    document.getElementById('pricing2ProgressBar').style.width = '0%';
  }
  function formatNum(x) {
    if (typeof x === 'number') return x.toLocaleString('ru-RU', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
    return x != null ? String(x) : '—';
  }
  function escapeHtml(s) {
    if (s == null) return '';
    var div = document.createElement('div');
    div.textContent = String(s);
    return div.innerHTML;
  }
  function getWeightedAvgPrice(articul) {
    var compList = competitorsByArticul[articul] || [];
    if (compList.length === 0) return null;
    var sumSalesPrice = 0;
    var sumSales = 0;
    compList.forEach(function(sku) {
      var mp = mpstatsData[sku];
      if (!mp) return;
      var sales = Number(mp.sales) || 0;
      var cardPrice = Number(mp.ozon_card_price);
      if (isNaN(cardPrice)) return;
      sumSalesPrice += sales * cardPrice;
      sumSales += sales;
    });
    if (sumSales <= 0) return null;
    return sumSalesPrice / sumSales;
  }
  function renderRow(row) {
    var articul = row['Артикул'] != null ? String(row['Артикул']).trim() : '';
    var info = ozonInfo[articul] || {};
    var img = info.primary_image
      ? '<img src="' + escapeHtml(info.primary_image) + '" alt="" loading="lazy">'
      : '—';
    var price = info.price !== undefined && info.price !== '' ? formatPrice(info.price) : '—';
    var sku = info.sku != null ? info.sku : null;
    var mp = sku != null ? mpstatsData[sku] : null;
    var ozonCardPrice = mp && mp.ozon_card_price != null ? formatPrice(String(mp.ozon_card_price)) : '—';
    var sales = mp && mp.sales != null ? String(mp.sales) : '—';
    var salesRub = mp && mp.sales_rub != null && mp.sales_rub !== '' ? formatPrice(String(mp.sales_rub)) : '—';
    var weightedAvg = getWeightedAvgPrice(articul);
    var recommended = weightedAvg != null ? weightedAvg * 0.98 : null;
    var recommendedStr = recommended != null ? formatPrice(String(recommended)) : '—';
    var compHtml = '<div class="add-form">' +
      '<input type="text" class="competitor-sku" placeholder="SKU" data-articul="' + escapeHtml(articul) + '" inputmode="numeric" pattern="[0-9]*">' +
      '<button type="button" class="btn-add-competitor" data-articul="' + escapeHtml(articul) + '">Добавить</button>' +
      '</div>';
    return '<tr>' +
      '<td>' + escapeHtml(articul) + '</td>' +
      '<td class="img-cell">' + img + '</td>' +
      '<td>' + escapeHtml(row['Номенклатура'] != null ? row['Номенклатура'] : '') + '</td>' +
      '<td>' + escapeHtml(row['ВидТовара'] != null ? row['ВидТовара'] : '') + '</td>' +
      '<td class="num">' + price + '</td>' +
      '<td class="num">' + ozonCardPrice + '</td>' +
      '<td class="num">' + sales + '</td>' +
      '<td class="num">' + salesRub + '</td>' +
      '<td class="num">' + recommendedStr + '</td>' +
      '<td class="competitors-cell">' + compHtml + '</td>' +
      '</tr>';
  }
  function renderCompetitorRow(articul, competitorSku) {
    var mp = mpstatsData[competitorSku];
    var ozonCardPrice = mp && mp.ozon_card_price != null ? formatPrice(String(mp.ozon_card_price)) : '—';
    var sales = mp && mp.sales != null ? String(mp.sales) : '—';
    var salesRub = mp && mp.sales_rub != null && mp.sales_rub !== '' ? formatPrice(String(mp.sales_rub)) : '—';
    var skuStr = escapeHtml(String(competitorSku));
    var ozonUrl = 'https://www.ozon.ru/product/' + skuStr;
    var link = '<a href="' + ozonUrl + '" target="_blank" rel="noopener noreferrer">Конкурент SKU ' + skuStr + '</a>';
    var removeBtn = '<button type="button" class="btn-remove-competitor" data-articul="' + escapeHtml(articul) + '" data-sku="' + escapeHtml(String(competitorSku)) + '" title="Удалить">×</button>';
    return '<tr class="competitor-row">' +
      '<td colspan="5">' + link + '</td>' +
      '<td class="num">' + ozonCardPrice + '</td>' +
      '<td class="num">' + sales + '</td>' +
      '<td class="num">' + salesRub + '</td>' +
      '<td></td>' +
      '<td class="competitors-cell">' + removeBtn + '</td>' +
      '</tr>';
  }
  function formatPrice(s) {
    if (s == null || s === '') return '—';
    var n = parseFloat(String(s).replace(/[^\\d.,]/g, '').replace(',', '.'));
    return isNaN(n) ? String(s) : n.toLocaleString('ru-RU', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function fillFilterVidTovara() {
    var seen = {};
    ppsDataAll.forEach(function(row) {
      var v = row['ВидТовара'] != null ? String(row['ВидТовара']).trim() : '';
      if (v && !seen[v]) { seen[v] = true; }
    });
    var options = Object.keys(seen).sort();
    var sel = document.getElementById('filterVidTovara');
    sel.innerHTML = '<option value="">Все виды</option>' + options.map(function(o) {
      return '<option value="' + escapeHtml(o) + '">' + escapeHtml(o) + '</option>';
    }).join('');
    sel.classList.remove('hidden');
  }
  function applyFilter() {
    var value = document.getElementById('filterVidTovara').value;
    var data = value ? ppsDataAll.filter(function(row) {
      var v = row['ВидТовара'] != null ? String(row['ВидТовара']).trim() : '';
      return v === value;
    }) : ppsDataAll;
    // После загрузки OZON показывать только товары, найденные неархивными хотя бы в одном кабинете; архивные во всех кабинетах не показываем
    if (Object.keys(ozonInfo).length > 0) {
      data = data.filter(function(row) {
        var a = row['Артикул'] != null ? String(row['Артикул']).trim() : '';
        return a && ozonInfo[a];
      });
    }
    var tbody = document.getElementById('ppsBody');
    if (data.length === 0) {
      tbody.innerHTML = '<tr><td colspan="10" class="text-center py-8 text-gray-500 dark:text-gray-400">Нет данных по выбранному виду товара</td></tr>';
      return;
    }
    var html = '';
    data.forEach(function(row) {
      html += renderRow(row);
      var articul = row['Артикул'] != null ? String(row['Артикул']).trim() : '';
      (competitorsByArticul[articul] || []).forEach(function(sku) {
        html += renderCompetitorRow(articul, sku);
      });
    });
    tbody.innerHTML = html;
  }
  function loadPps() {
    setLoading(true);
    hideError();
    hideProgress();
    setProgress(5, 'Загрузка PPS...');
    fetch('/pricing2/api/pps')
      .then(function(r) {
        if (!r.ok) throw new Error(r.status + ' ' + r.statusText);
        return r.json();
      })
      .then(function(data) {
        var tbody = document.getElementById('ppsBody');
        if (!Array.isArray(data) || data.length === 0) {
          ppsDataAll = [];
          ozonInfo = {};
          mpstatsData = {};
          tbody.innerHTML = '<tr><td colspan="10" class="text-center py-8 text-gray-500 dark:text-gray-400">Нет данных</td></tr>';
          document.getElementById('filterVidTovara').classList.add('hidden');
          setLoading(false);
          hideProgress();
          return;
        }
        ppsDataAll = data;
        fillFilterVidTovara();
        setProgress(33, 'Загрузка OZON (фото, цены, SKU)...');
        loadOzonInfo();
      })
      .catch(function(err) {
        showError(err.message || 'Не удалось загрузить данные');
        document.getElementById('ppsBody').innerHTML = '<tr><td colspan="10" class="text-center py-8 text-gray-500 dark:text-gray-400">Ошибка загрузки</td></tr>';
        document.getElementById('filterVidTovara').classList.add('hidden');
        setLoading(false);
        hideProgress();
      });
  }
  function loadOzonInfo() {
    var articuls = [];
    ppsDataAll.forEach(function(row) {
      var a = row['Артикул'] != null ? String(row['Артикул']).trim() : '';
      if (a && articuls.indexOf(a) === -1) articuls.push(a);
    });
    if (articuls.length === 0) {
      ozonInfo = {};
      applyFilter();
      setLoading(false);
      hideProgress();
      return;
    }
    fetch('/pricing2/api/ozon-products', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ offer_ids: articuls })
    })
      .then(function(r) {
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.error || r.status); });
        return r.json();
      })
      .then(function(data) {
        ozonInfo = data.items || {};
        applyFilter();
        setProgress(66, 'Загрузка MPStats (цена по OZON карте, продажи)...');
        loadMpstatsSales();
      })
      .catch(function(err) {
        ozonInfo = {};
        applyFilter();
        setLoading(false);
        hideProgress();
        showError('Не удалось загрузить данные OZON: ' + (err.message || err));
      });
  }
  function loadMpstatsSales() {
    var skus = [];
    for (var k in ozonInfo) {
      if (ozonInfo[k].sku != null) skus.push(ozonInfo[k].sku);
    }
    for (var a in competitorsByArticul) {
      (competitorsByArticul[a] || []).forEach(function(sku) {
        if (sku && skus.indexOf(Number(sku)) === -1) skus.push(Number(sku));
      });
    }
    if (skus.length === 0) {
      mpstatsData = {};
      applyFilter();
      setLoading(false);
      hideProgress();
      return;
    }
    setProgress(66, 'Загрузка MPStats (цена по OZON карте, продажи)...');
    fetch('/pricing2/api/mpstats-sales', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ skus: skus })
    })
      .then(function(r) {
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.error || r.status); });
        return r.json();
      })
      .then(function(data) {
        mpstatsData = data.items || {};
        applyFilter();
        setProgress(100, 'Готово');
        setLoading(false);
        hideProgress();
        saveOurProductsToServer();
        saveCompetitorsToServer();
      })
      .catch(function(err) {
        mpstatsData = {};
        applyFilter();
        setLoading(false);
        hideProgress();
        showError('Не удалось загрузить данные MPStats: ' + (err.message || err));
      });
  }
  function loadMpstatsSalesForSkus(skus) {
    if (!skus || skus.length === 0) return;
    fetch('/pricing2/api/mpstats-sales', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ skus: skus })
    })
      .then(function(r) {
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.error || r.status); });
        return r.json();
      })
      .then(function(data) {
        if (data.items && typeof data.items === 'object') {
          for (var k in data.items) mpstatsData[k] = data.items[k];
        }
        applyFilter();
        saveCompetitorsToServer();
      })
      .catch(function(err) {
        showError('Не удалось загрузить данные MPStats для конкурента: ' + (err.message || err));
        applyFilter();
      });
  }
  function eventTargetElement(e) {
    var t = e.target;
    return (t && t.nodeType === 1) ? t : (t && t.parentElement) || null;
  }
  document.getElementById('ppsBody').addEventListener('click', function(e) {
    var el = eventTargetElement(e);
    var btn = el && el.closest('.btn-add-competitor');
    if (btn) {
      var articul = btn.getAttribute('data-articul');
      var cell = btn.closest('td');
      var input = cell && cell.querySelector('input.competitor-sku');
      var skuStr = input && input.value.trim();
      var sku = skuStr ? parseInt(skuStr, 10) : NaN;
      if (!articul || !skuStr || isNaN(sku) || sku <= 0) return;
      if (!competitorsByArticul[articul]) competitorsByArticul[articul] = [];
      if (competitorsByArticul[articul].indexOf(sku) !== -1) return;
      competitorsByArticul[articul].push(sku);
      input.value = '';
      loadMpstatsSalesForSkus([sku]);
      return;
    }
    var removeBtn = el && el.closest('.btn-remove-competitor');
    if (removeBtn) {
      var articul = removeBtn.getAttribute('data-articul');
      var sku = removeBtn.getAttribute('data-sku');
      if (!articul || !sku) return;
      var list = competitorsByArticul[articul];
      if (list) {
        var n = Number(sku);
        competitorsByArticul[articul] = list.filter(function(s) { return Number(s) !== n; });
        if (competitorsByArticul[articul].length === 0) delete competitorsByArticul[articul];
        saveCompetitorsToServer();
      }
      applyFilter();
    }
  });

  function loadFromFiles() {
    Promise.all([
      fetch('/pricing2/api/our-products').then(function(r) { return r.json().then(function(d) { return d; }).catch(function() { return {}; }); }),
      fetch('/pricing2/api/competitors').then(function(r) { return r.json(); })
    ]).then(function(results) {
      var our = results[0] || {};
      var comp = results[1] || {};
      if (Array.isArray(our.ppsData) && our.ppsData.length > 0) {
        ppsDataAll = our.ppsData;
        ozonInfo = our.ozonInfo && typeof our.ozonInfo === 'object' ? our.ozonInfo : {};
        mpstatsData = our.mpstatsData && typeof our.mpstatsData === 'object' ? our.mpstatsData : {};
      }
      if (comp && comp.competitorsByArticul && typeof comp.competitorsByArticul === 'object') {
        competitorsByArticul = comp.competitorsByArticul;
      }
      if (comp && comp.mpstatsData && typeof comp.mpstatsData === 'object') {
        for (var k in comp.mpstatsData) mpstatsData[k] = comp.mpstatsData[k];
      }
